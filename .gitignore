# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# uv
.python-version

# Environment
.env
*.env.local

# Gmail OAuth tokens (sensitive)
token.json
credentials.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Content of raw/ and wiki/ is NOT committed — only the directory structure.
# This keeps the repo clean while letting us move to a real datastore later.
# The .gitkeep files in each subdirectory preserve the tree layout in git.
raw/*.md
raw/attachments/**/*
!raw/attachments/.gitkeep
wiki/*.md
wiki/topics/*.md
# `entities/` is the legacy path (pre-v10-U1); `people/` is the new path.
# Ignoring both until every worktree is migrated prevents a pre-migration
# branch from committing stale `wiki/entities/*.md` under the current config.
wiki/entities/*.md
wiki/people/*.md
wiki/systems/*.md
wiki/policies/*.md

# Langfuse / tracing
.langfuse/

# Gmail state
.gmail_history_id

# Wiki snapshots for safe experimentation (see scripts/snapshot_wiki.py)
.snapshots/

# Tool harness large-output dumps (accidental commits from Bash tool overflow)
large_tool_results/

# Test artifacts
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Broken-wikilink audit files (generated by scripts/fix_broken_wikilinks.py
# and pytest --commit runs; not source-of-truth artifacts).
docs/audits/broken-wikilinks-*.md

# Legacy-debt nightly migration reports (generated by
# scripts/migrate_legacy_pages.py; regenerated each run).
docs/audits/legacy-debt-*.md

# Wiki scorer + LLM judge outputs (scripts/score_wiki.py, scripts/judge_wiki.py)
# — regenerated each run. Outputs, not source.
docs/feedback/scorer-*.csv
docs/feedback/scorer-*.md
docs/feedback/judge-*.csv
docs/feedback/judge-*.md

# MkDocs build
site/

# Compile run logs
logs/

# Claude Code local settings / worktrees
.claude/

# Playwright MCP debug logs
.playwright-mcp/

# Chroma vector index (rebuild with: python scripts/index_wiki.py)
.chroma_index/

# QMD hybrid search index (rebuild with: qmd collection add + qmd embed)
.qmd/

# Test wiki copy
wiki2/

# Wiki tree and graph (rebuild with: python scripts/index_wiki.py)
wiki/wiki_tree.json
wiki/wiki_graph.json

# Email KB dump
email_kb_dump.sql

# Node modules (QMD)
node_modules/

# macOS resource forks
._*
