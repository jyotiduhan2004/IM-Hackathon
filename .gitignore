# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# uv
.python-version

# Environment
.env
*.env.local

# Gmail OAuth tokens (sensitive)
token.json
credentials.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Content of raw/ and wiki/ is NOT committed — only the directory structure.
# This keeps the repo clean while letting us move to a real datastore later.
# The .gitkeep files in each subdirectory preserve the tree layout in git.
raw/*.md
raw/attachments/**/*
!raw/attachments/.gitkeep
wiki/*.md
wiki/topics/*.md
wiki/entities/*.md
wiki/systems/*.md
wiki/policies/*.md
wiki/timelines/*.md
wiki/conflicts/*.md

# Langfuse / tracing
.langfuse/

# Gmail state
.gmail_history_id

# Wiki snapshots for safe experimentation (see scripts/snapshot_wiki.py)
.snapshots/

# Tool harness large-output dumps (accidental commits from Bash tool overflow)
large_tool_results/

# Test artifacts
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# MkDocs build
site/

# Compile run logs
logs/

# Claude Code local settings / worktrees
.claude/
