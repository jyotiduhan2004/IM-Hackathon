# === LLM Configuration ===
# LiteLLM-compatible model string. Used only as a fallback for code paths
# that invoke run_compilation without an explicit model (one-off scripts,
# tests). Production compile runs pick per-batch from LLM_MODEL_POOL and
# the auto-exclusion guard in scripts/compile_all.py::_healthy_pool drops
# models with >50% failure over the last 24h or 10+ absolute failures.
LLM_MODEL=minimax/minimax-m2.7

# Per-batch model A/B pool — comma-separated. compile_all.py picks one
# uniformly at random per batch (sticky for the batch) and stamps the
# choice into messages.compile_model so we can join model → outcome.
# Set to a single value (or empty string) to disable A/B routing.
# Defaults below; override here if you want a different mix.
# LLM_MODEL_POOL=minimax/minimax-m2.7,z-ai/glm-5,deepseek/deepseek-v3.2,xiaomi/mimo-v2-pro,x-ai/grok-4.1-fast

# If using LiteLLM proxy, set the base URL
LITELLM_BASE_URL=http://localhost:4000
# API keys (set whichever provider you use)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# === Gmail Configuration ===
# Path to OAuth credentials JSON (downloaded from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=credentials.json
# Path to store OAuth token (auto-created after first auth)
GMAIL_TOKEN_PATH=token.json
# Mailing list address to filter emails from
MAILING_LIST_ADDRESS=your-list@company.com
# Gmail user to impersonate (for service accounts with domain-wide delegation)
# GMAIL_DELEGATED_USER=user@company.com

# === Langfuse Observability ===
# Self-hosted Langfuse at langfuse.intermesh.net (preferred for IndiaMart projects).
# Get keys from the project page → Settings → API Keys, then store in 1Password.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://langfuse.intermesh.net
# Default OFF until the server-side OTLP hang (issue #17) is resolved.
# The compile pipeline has bounded export timeouts (~2s) so enabling is
# safe — it just means traces may drop while the server is slow.
LANGFUSE_ENABLED=false

# === Semantic Retrieval (qmd) ===
# When set to 1, resolve_page consults a semantic retriever (qmd) for
# candidate pages on a miss, returning relevance-ordered results with
# line-numbered body snippets. Exact slug/title/email matches still
# win from the Postgres catalog regardless of this flag.
# Prerequisites when enabled: `qmd` installed + wiki indexed (see
# scripts/qmd_index.sh or `docs/audits/qmd-spike-2026-04-23.md`).
# Set to 0 for the legacy SQL-ILIKE behaviour (safe rollback).
USE_SEMANTIC_RESOLVE=0
# Hard per-call timeout in seconds. Default 60 (raised from 45 after
# run 5928c151 trace audit showed 15.4% of calls hitting the cap with
# p95 latency on the cliff). Lower if semantic is unavailable and you
# want faster fallbacks to the ILIKE path.
QMD_TIMEOUT_S=60

# === Paths (defaults work for local development) ===
RAW_DIR=raw
WIKI_DIR=wiki
